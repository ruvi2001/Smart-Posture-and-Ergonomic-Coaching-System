# Server
PORT=5000

# MongoDB Atlas or local MongoDB URI
# Example Atlas:
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/smart_posture_db?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://tinyml439_db_user:ZnEEQFedEVQFlunw@smart-posture-cluster.mqnj8yq.mongodb.net/

# MQTT settings. Must match the ESP32 MQTT broker/topic.
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_TOPIC=posture/chair01/readings

# Session/occupancy thresholds based on raw ADC values.
FSR_OCCUPIED_ADC_THRESHOLD=1000
FSR_TOTAL_OCCUPIED_THRESHOLD=5000
SESSION_END_MINUTES=5

# Posture classification thresholds.
POSTURE_LR_THRESHOLD=0.18
POSTURE_FORWARD_DISTANCE_MIN_CM=30
POSTURE_FORWARD_DISTANCE_MAX_CM=45
POSTURE_BACKWARD_DISTANCE_MIN_CM=72
POSTURE_BACKWARD_DISTANCE_MAX_CM=95
POSTURE_FORWARD_ACCEL_Y=0.35
POSTURE_BACKWARD_ACCEL_Y=-0.70
POSTURE_BACKWARD_FB_BALANCE=-0.23
POSTURE_FORWARD_FB_BALANCE=-0.08

# ADXL345 good-posture baseline from your collected readings.
ACCEL_BASELINE_X=-9.85
ACCEL_BASELINE_Y=0.05
ACCEL_BASELINE_Z=-0.90

# Alert spam control. ESP32 publishes every few seconds, so do not save alert every reading.
ALERT_COOLDOWN_SECONDS=60
